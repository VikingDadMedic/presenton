{
  "openapi": "3.1.0",
  "info": {
    "title": "TripStory API",
    "version": "0.2.0",
    "description": "TripStory is a visual travel experience builder. Generate presentations from prompts, fetch structured data, and export in multiple formats."
  },
  "paths": {
    "/api/v1/ppt/presentation/generate": {
      "post": {
        "tags": ["Presentation"],
        "summary": "Generate a complete presentation and export as PPTX, PDF, or HTML.",
        "operationId": "generate_presentation",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GeneratePresentationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Presentation generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PresentationPathAndEditPath"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/presentation/{id}": {
      "get": {
        "tags": ["Presentation"],
        "summary": "Get a presentation with all slides (JSON export).",
        "description": "Returns the full presentation model including all slides with their structured JSON content, layout info, speaker notes, theme, and metadata. This is the programmatic JSON export format -- consumers can use the structured slide data for CRM integration, email templates, or custom rendering.",
        "operationId": "get_presentation",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Presentation ID (UUID returned from generate)"
          }
        ],
        "responses": {
          "200": {
            "description": "Presentation with all slides",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PresentationWithSlides"
                }
              }
            }
          },
          "404": {
            "description": "Presentation not found"
          }
        }
      }
    },
    "/api/v1/ppt/presentation/export": {
      "post": {
        "tags": ["Presentation"],
        "summary": "Export an existing presentation as PPTX, PDF, or HTML.",
        "operationId": "export_presentation",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Presentation ID to export"
                  },
                  "export_as": {
                    "type": "string",
                    "enum": ["pptx", "pdf", "html", "video"],
                    "default": "pptx",
                    "description": "Export format (video = MP4 slideshow)"
                  },
                  "export_options": {
                    "type": "object",
                    "description": "Format-specific options (slide_duration, transition_style, etc.)",
                    "properties": {
                      "slide_duration": { "type": "integer", "description": "Seconds per slide" },
                      "transition_style": { "type": "string", "enum": ["scale-zoom", "slide-right", "clip-reveal", "cycle", "random"] },
                      "transition_duration": { "type": "number", "description": "Transition duration in seconds" },
                      "audio_url": { "type": "string", "description": "Background audio URL for video" },
                      "auto_play_interval": { "type": "integer", "description": "Auto-play interval in ms for HTML" }
                    }
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Export path and edit URL",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PresentationPathAndEditPath"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/slide/edit-field": {
      "patch": {
        "tags": ["Slide"],
        "summary": "Edit a single field on a slide using AI.",
        "operationId": "edit_slide_field",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id", "field_path", "prompt"],
                "properties": {
                  "id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Slide ID"
                  },
                  "field_path": {
                    "type": "string",
                    "description": "Dot-notation path to the field (e.g. 'tiers.0.price')"
                  },
                  "prompt": {
                    "type": "string",
                    "description": "Instruction for how to edit the field"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Updated slide"
          }
        }
      }
    },
    "/api/v1/ppt/enrichers/status": {
      "get": {
        "tags": ["Enrichers"],
        "summary": "Check which travel enricher API keys are configured.",
        "description": "Returns lists of available and unavailable enrichers. Available enrichers have all required API keys set. Unavailable ones list their missing keys.",
        "operationId": "get_enricher_status",
        "responses": {
          "200": {
            "description": "Enricher availability status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "available": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "Names of enrichers with all API keys configured"
                    },
                    "unavailable": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": { "type": "string" },
                          "missing_keys": {
                            "type": "array",
                            "items": { "type": "string" }
                          }
                        }
                      },
                      "description": "Enrichers missing API keys"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/presentation/all": {
      "get": {
        "tags": ["Presentation"],
        "summary": "List all presentations.",
        "operationId": "list_presentations",
        "responses": {
          "200": {
            "description": "All presentations with slides",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PresentationWithSlides"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/template-management/summary": {
      "get": {
        "tags": ["template-management"],
        "summary": "Get all custom templates with layout counts.",
        "description": "Returns a list of custom templates available for presentation creation.",
        "operationId": "templates_list",
        "responses": {
          "200": {
            "description": "Templates summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetPresentationSummaryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/export-as-embed": {
      "post": {
        "tags": ["Presentation"],
        "summary": "Get embed URL and iframe code for interactive presentation player.",
        "operationId": "get_embed_url",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": { "type": "string", "format": "uuid", "description": "Presentation ID" }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Embed URL and iframe code",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "embed_url": { "type": "string" },
                    "iframe_code": { "type": "string" },
                    "presentation_id": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/presentation/export/json/{id}": {
      "get": {
        "tags": ["Presentation"],
        "summary": "Download presentation as structured JSON file.",
        "operationId": "export_json",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "JSON file download",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PresentationWithSlides" }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/presentation/generate/async": {
      "post": {
        "tags": ["Presentation"],
        "summary": "Start async presentation generation. Poll /status/{id} for completion.",
        "operationId": "generate_async",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GeneratePresentationRequest" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Task created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "status": { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GeneratePresentationRequest": {
        "type": "object",
        "required": ["content"],
        "properties": {
          "content": {
            "type": "string",
            "description": "The content/prompt for generating the presentation"
          },
          "n_slides": {
            "type": "integer",
            "description": "Number of slides. If omitted, auto-detected.",
            "default": 8
          },
          "language": {
            "type": "string",
            "description": "Presentation language. If omitted, auto-detected.",
            "default": "English"
          },
          "template": {
            "type": "string",
            "description": "Template group: general, travel, travel-itinerary, code, education, product-overview, report, etc.",
            "default": "general"
          },
          "tone": {
            "type": "string",
            "enum": ["default", "casual", "professional", "funny", "educational", "sales_pitch", "inspirational", "adventurous", "luxury"],
            "default": "default"
          },
          "verbosity": {
            "type": "string",
            "enum": ["concise", "standard", "text-heavy"],
            "default": "standard"
          },
          "web_search": {
            "type": "boolean",
            "default": false,
            "description": "Enable web search grounding"
          },
          "include_table_of_contents": {
            "type": "boolean",
            "default": false
          },
          "include_title_slide": {
            "type": "boolean",
            "default": true
          },
          "export_as": {
            "type": "string",
            "enum": ["pptx", "pdf", "html", "video"],
            "default": "pptx"
          },
          "origin": {
            "type": "string",
            "description": "Departure city for travel flight searches"
          },
          "currency": {
            "type": "string",
            "default": "USD",
            "description": "Currency for price formatting"
          },
          "slides_markdown": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Custom slide outlines"
          },
          "instructions": {
            "type": "string",
            "description": "Custom instructions for the AI"
          },
          "trigger_webhook": {
            "type": "boolean",
            "default": false
          },
          "slide_duration": {
            "type": "integer",
            "description": "Seconds per slide for video/HTML export"
          },
          "transition_style": {
            "type": "string",
            "enum": ["scale-zoom", "slide-right", "clip-reveal", "cycle", "random"],
            "default": "cycle",
            "description": "Video transition animation style"
          }
        }
      },
      "PresentationWithSlides": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "content": { "type": "string" },
          "n_slides": { "type": "integer" },
          "language": { "type": "string" },
          "title": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "tone": { "type": "string" },
          "verbosity": { "type": "string" },
          "theme": { "type": "object" },
          "slides": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/SlideModel" }
          }
        }
      },
      "SlideModel": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "layout_group": { "type": "string", "description": "Template group (e.g. 'travel', 'general')" },
          "layout": { "type": "string", "description": "Layout ID (e.g. 'travel:destination-hero')" },
          "index": { "type": "integer" },
          "content": { "type": "object", "description": "Structured slide data matching the layout's Zod schema" },
          "speaker_note": { "type": "string" },
          "html_content": { "type": "string" }
        }
      },
      "PresentationPathAndEditPath": {
        "type": "object",
        "required": ["presentation_id", "path", "edit_path"],
        "properties": {
          "presentation_id": { "type": "string" },
          "path": { "type": "string", "description": "File path to the exported file" },
          "edit_path": { "type": "string", "description": "URL path to edit the presentation in the UI" }
        }
      },
      "HTTPValidationError": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ValidationError" }
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "required": ["loc", "msg", "type"],
        "properties": {
          "loc": { "type": "array", "items": { "type": "string" } },
          "msg": { "type": "string" },
          "type": { "type": "string" }
        }
      },
      "GetPresentationSummaryResponse": {
        "type": "object",
        "required": ["success", "presentations", "total_presentations", "total_layouts"],
        "properties": {
          "success": { "type": "boolean" },
          "presentations": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PresentationSummary" }
          },
          "total_presentations": { "type": "integer" },
          "total_layouts": { "type": "integer" },
          "message": { "type": "string" }
        }
      },
      "PresentationSummary": {
        "type": "object",
        "required": ["presentation_id", "layout_count"],
        "properties": {
          "presentation_id": { "type": "string" },
          "layout_count": { "type": "integer" },
          "last_updated_at": { "type": "string", "format": "date-time" },
          "template": { "type": "object" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["detail"],
        "properties": {
          "success": { "type": "boolean", "default": false },
          "detail": { "type": "string" },
          "error_code": { "type": "string" }
        }
      }
    }
  }
}
