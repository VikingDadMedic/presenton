{
  "openapi": "3.1.0",
  "info": {
    "title": "TripStory API",
    "version": "0.2.0",
    "description": "TripStory is a visual travel experience builder. Generate presentations from prompts, fetch structured data, and export in multiple formats."
  },
  "paths": {
    "/api/v1/ppt/presentation/generate": {
      "post": {
        "tags": ["Presentation"],
        "summary": "Generate a complete presentation and export as PPTX, PDF, or HTML.",
        "operationId": "generate_presentation",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GeneratePresentationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Presentation generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PresentationPathAndEditPath"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/presentation/{id}": {
      "get": {
        "tags": ["Presentation"],
        "summary": "Get a presentation with all slides (JSON export).",
        "description": "Returns the full presentation model including all slides with their structured JSON content, layout info, speaker notes, theme, and metadata. This is the programmatic JSON export format -- consumers can use the structured slide data for CRM integration, email templates, or custom rendering.",
        "operationId": "get_presentation",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Presentation ID (UUID returned from generate)"
          }
        ],
        "responses": {
          "200": {
            "description": "Presentation with all slides",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PresentationWithSlides"
                }
              }
            }
          },
          "404": {
            "description": "Presentation not found"
          }
        }
      }
    },
    "/api/v1/ppt/presentation/export": {
      "post": {
        "tags": ["Presentation"],
        "summary": "Export an existing presentation as PPTX, PDF, or HTML.",
        "operationId": "export_presentation",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Presentation ID to export"
                  },
                  "export_as": {
                    "type": "string",
                    "enum": ["pptx", "pdf", "html", "video"],
                    "default": "pptx",
                    "description": "Export format (video = MP4 slideshow)"
                  },
                  "export_options": {
                    "type": "object",
                    "description": "Format-specific options (slide_duration, transition_style, etc.)",
                    "properties": {
                      "slide_duration": { "type": "integer", "description": "Seconds per slide" },
                      "transition_style": { "type": "string", "enum": ["scale-zoom", "slide-right", "clip-reveal", "cycle", "random"] },
                      "transition_duration": { "type": "number", "description": "Transition duration in seconds" },
                      "audio_url": { "type": "string", "description": "Background audio URL for video" },
                      "auto_play_interval": { "type": "integer", "description": "Auto-play interval in ms for HTML" },
                      "aspect_ratio": {
                        "type": "string",
                        "enum": ["landscape", "vertical", "square"],
                        "description": "Export canvas aspect ratio"
                      }
                    }
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Export path and edit URL",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PresentationPathAndEditPath"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/slide/edit-field": {
      "patch": {
        "tags": ["Slide"],
        "summary": "Edit a single field on a slide using AI.",
        "operationId": "edit_slide_field",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id", "field_path", "prompt"],
                "properties": {
                  "id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Slide ID"
                  },
                  "field_path": {
                    "type": "string",
                    "description": "Dot-notation path to the field (e.g. 'tiers.0.price')"
                  },
                  "prompt": {
                    "type": "string",
                    "description": "Instruction for how to edit the field"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Updated slide"
          }
        }
      }
    },
    "/api/v1/ppt/enrichers/status": {
      "get": {
        "tags": ["Enrichers"],
        "summary": "Check which travel enricher API keys are configured.",
        "description": "Returns lists of available and unavailable enrichers. Available enrichers have all required API keys set. Unavailable ones list their missing keys.",
        "operationId": "get_enricher_status",
        "responses": {
          "200": {
            "description": "Enricher availability status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "available": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "Names of enrichers with all API keys configured"
                    },
                    "unavailable": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": { "type": "string" },
                          "missing_keys": {
                            "type": "array",
                            "items": { "type": "string" }
                          }
                        }
                      },
                      "description": "Enrichers missing API keys"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/presentation/all": {
      "get": {
        "tags": ["Presentation"],
        "summary": "List all presentations.",
        "operationId": "list_presentations",
        "responses": {
          "200": {
            "description": "All presentations with slides",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PresentationWithSlides"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/template-management/summary": {
      "get": {
        "tags": ["template-management"],
        "summary": "Get all custom templates with layout counts.",
        "description": "Returns a list of custom templates available for presentation creation.",
        "operationId": "templates_list",
        "responses": {
          "200": {
            "description": "Templates summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetPresentationSummaryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/export-as-embed": {
      "post": {
        "tags": ["Presentation"],
        "summary": "Get embed URL and iframe code for interactive presentation player.",
        "operationId": "get_embed_url",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": { "type": "string", "format": "uuid", "description": "Presentation ID" }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Embed URL and iframe code",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "embed_url": { "type": "string" },
                    "iframe_code": { "type": "string" },
                    "presentation_id": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/presentation/export/json/{id}": {
      "get": {
        "tags": ["Presentation"],
        "summary": "Download presentation as structured JSON file.",
        "operationId": "export_json",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "JSON file download",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PresentationWithSlides" }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/presentation/generate/async": {
      "post": {
        "tags": ["Presentation"],
        "summary": "Start async presentation generation. Poll /status/{id} for completion.",
        "operationId": "generate_async",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GeneratePresentationRequest" }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Task created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "status": { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/campaign/generate": {
      "post": {
        "tags": ["Campaign"],
        "summary": "Generate a multi-variant campaign asynchronously.",
        "operationId": "generate_campaign",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "content": { "type": "string" },
                  "instructions": { "type": "string" },
                  "trip_plan": { "type": "object", "additionalProperties": true },
                  "n_slides": { "type": "integer" },
                  "language": { "type": "string" },
                  "verbosity": { "type": "string" },
                  "web_search": { "type": "boolean" },
                  "include_table_of_contents": { "type": "boolean" },
                  "include_title_slide": { "type": "boolean" },
                  "origin": { "type": "string" },
                  "currency": { "type": "string" },
                  "variants": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": { "type": "string" },
                        "template": { "type": "string" },
                        "export_as": {
                          "type": "string",
                          "enum": ["pptx", "pdf", "html", "video"]
                        },
                        "tone": { "type": "string" },
                        "narration_tone": { "type": "string" },
                        "verbosity": { "type": "string" },
                        "instructions": { "type": "string" },
                        "n_slides": { "type": "integer" },
                        "language": { "type": "string" },
                        "slide_duration": { "type": "integer" },
                        "transition_style": { "type": "string" },
                        "transition_duration": { "type": "number" },
                        "use_narration_as_soundtrack": { "type": "boolean" },
                        "lead_magnet": { "type": "boolean" },
                        "email_safe": { "type": "boolean" },
                        "utm_source": { "type": "string" },
                        "utm_medium": { "type": "string" },
                        "utm_campaign": { "type": "string" },
                        "utm_content": { "type": "string" },
                        "aspect_ratio": { "type": "string" },
                        "is_public": { "type": "boolean" }
                      },
                      "required": ["name", "template", "export_as"],
                      "additionalProperties": true
                    }
                  }
                },
                "required": ["content", "variants"],
                "additionalProperties": true
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Campaign generation started",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "campaign_id": { "type": "string" },
                    "statusUrl": { "type": "string" }
                  },
                  "required": ["campaign_id", "statusUrl"]
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/campaign/status/{campaign_id}": {
      "get": {
        "tags": ["Campaign"],
        "summary": "Get campaign generation status and variant outcomes.",
        "operationId": "get_campaign_status",
        "parameters": [
          {
            "name": "campaign_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign status payload",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "campaign_id": { "type": "string" },
                    "status": { "type": "string" },
                    "created_at": { "type": "string" },
                    "updated_at": { "type": "string" },
                    "started_at": { "type": "string", "nullable": true },
                    "completed_at": { "type": "string", "nullable": true },
                    "error": { "type": "string", "nullable": true },
                    "variants": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "variant_id": { "type": "string" },
                          "name": { "type": "string" },
                          "template": { "type": "string" },
                          "export_as": { "type": "string" },
                          "status": { "type": "string" },
                          "created_at": { "type": "string" },
                          "updated_at": { "type": "string" },
                          "started_at": { "type": "string", "nullable": true },
                          "completed_at": { "type": "string", "nullable": true },
                          "error": { "type": "string", "nullable": true },
                          "artifact": {
                            "type": "object",
                            "nullable": true,
                            "additionalProperties": true
                          }
                        },
                        "required": [
                          "variant_id",
                          "name",
                          "template",
                          "export_as",
                          "status",
                          "created_at",
                          "updated_at"
                        ],
                        "additionalProperties": true
                      }
                    }
                  },
                  "required": [
                    "campaign_id",
                    "status",
                    "created_at",
                    "updated_at",
                    "variants"
                  ],
                  "additionalProperties": true
                }
              }
            }
          },
          "404": {
            "description": "Campaign not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/campaign-presets": {
      "get": {
        "tags": ["CampaignPresets"],
        "summary": "List saved campaign variant presets.",
        "operationId": "get_campaign_presets",
        "responses": {
          "200": {
            "description": "Saved campaign variant presets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "presets": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/CampaignVariantPreset" }
                    }
                  },
                  "required": ["presets"]
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["CampaignPresets"],
        "summary": "Replace the saved campaign variant presets list.",
        "operationId": "update_campaign_presets",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "presets": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/CampaignVariantPreset" }
                  }
                },
                "required": ["presets"]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Updated campaign variant presets",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "presets": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/CampaignVariantPreset" }
                    }
                  },
                  "required": ["presets"]
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HTTPValidationError" }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/profile": {
      "get": {
        "tags": ["Profile"],
        "summary": "Get persisted agent profile defaults.",
        "operationId": "get_agent_profile",
        "responses": {
          "200": {
            "description": "Agent profile payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentProfile"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["Profile"],
        "summary": "Update agent profile defaults.",
        "operationId": "update_agent_profile",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentProfile"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Updated agent profile payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentProfile"
                }
              }
            }
          },
          "404": {
            "description": "Logo not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "detail": { "type": "string" }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/presentation/recap": {
      "post": {
        "tags": ["Presentation"],
        "summary": "Generate a recap presentation from an existing trip deck or source JSON.",
        "operationId": "generate_recap",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "mode": {
                    "type": "string",
                    "enum": [
                      "welcome_home",
                      "anniversary",
                      "next_planning_window"
                    ]
                  },
                  "source_presentation_id": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "source_json": {
                    "type": "object",
                    "additionalProperties": true
                  },
                  "template": { "type": "string" },
                  "n_slides": { "type": "integer" },
                  "language": { "type": "string" },
                  "tone": { "type": "string" },
                  "narration_tone": { "type": "string" },
                  "verbosity": { "type": "string" },
                  "instructions": { "type": "string" },
                  "web_search": { "type": "boolean" },
                  "include_table_of_contents": { "type": "boolean" },
                  "include_title_slide": { "type": "boolean" },
                  "export_as": {
                    "type": "string",
                    "enum": ["pptx", "pdf", "html", "video"]
                  },
                  "origin": { "type": "string" },
                  "currency": { "type": "string" },
                  "slide_duration": { "type": "integer" },
                  "transition_style": { "type": "string" },
                  "transition_duration": { "type": "number" },
                  "use_narration_as_soundtrack": { "type": "boolean" },
                  "export_options": {
                    "type": "object",
                    "additionalProperties": true
                  }
                },
                "required": ["mode"],
                "additionalProperties": true
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Recap presentation generated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "presentation_id": { "type": "string", "format": "uuid" },
                    "path": { "type": "string" },
                    "edit_path": { "type": "string" },
                    "mode": { "type": "string" },
                    "source_presentation_id": {
                      "type": "string",
                      "format": "uuid",
                      "nullable": true
                    }
                  },
                  "required": ["presentation_id", "path", "edit_path", "mode"]
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/narration/voices": {
      "get": {
        "tags": ["Narration"],
        "summary": "List available narration voices.",
        "operationId": "get_narration_voices",
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Optional voice name filter"
          }
        ],
        "responses": {
          "200": {
            "description": "Narration voice catalog",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NarrationVoicesResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/narration/presentation/{presentation_id}/estimate": {
      "get": {
        "tags": ["Narration"],
        "summary": "Estimate narration character usage for a presentation.",
        "operationId": "narration_estimate",
        "parameters": [
          {
            "name": "presentation_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Narration estimate",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NarrationEstimateResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/narration/presentation/{presentation_id}/bulk": {
      "post": {
        "tags": ["Narration"],
        "summary": "Generate narration audio for all slides in a presentation.",
        "operationId": "bulk_generate_narration",
        "parameters": [
          {
            "name": "presentation_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/NarrationGenerateRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk narration generation result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NarrationBulkResponse" }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/narration/presentation/{presentation_id}": {
      "get": {
        "tags": ["Narration"],
        "summary": "Get narration status for all slides in a presentation.",
        "operationId": "get_narration_status",
        "parameters": [
          {
            "name": "presentation_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Per-slide narration status",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/NarrationPresentationStatusResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AgentProfile": {
        "type": "object",
        "properties": {
          "agent_name": { "type": "string", "nullable": true },
          "agency_name": { "type": "string", "nullable": true },
          "email": { "type": "string", "nullable": true },
          "phone": { "type": "string", "nullable": true },
          "booking_url": { "type": "string", "nullable": true },
          "tagline": { "type": "string", "nullable": true },
          "logo_url": { "type": "string", "nullable": true },
          "default_utm_source": { "type": "string", "nullable": true },
          "default_utm_medium": { "type": "string", "nullable": true },
          "default_utm_campaign": { "type": "string", "nullable": true }
        },
        "additionalProperties": false
      },
      "CampaignVariantPreset": {
        "type": "object",
        "required": ["id", "label", "name"],
        "properties": {
          "id": { "type": "string", "description": "Stable preset id (uuid)" },
          "label": { "type": "string", "description": "Display label" },
          "description": { "type": "string", "nullable": true },
          "created_at": { "type": "string", "format": "date-time" },
          "name": { "type": "string", "description": "Variant name passed to /campaign/generate" },
          "template": { "type": "string", "default": "travel-itinerary" },
          "export_as": {
            "type": "string",
            "enum": ["pptx", "pdf", "html", "video"],
            "default": "pptx"
          },
          "tone": { "type": "string", "nullable": true },
          "narration_tone": { "type": "string", "nullable": true },
          "verbosity": { "type": "string", "nullable": true },
          "instructions": { "type": "string", "nullable": true },
          "n_slides": { "type": "integer", "nullable": true },
          "language": { "type": "string", "nullable": true },
          "slide_duration": { "type": "integer", "nullable": true },
          "transition_style": { "type": "string", "nullable": true },
          "transition_duration": { "type": "number", "nullable": true },
          "use_narration_as_soundtrack": { "type": "boolean", "nullable": true },
          "lead_magnet": { "type": "boolean", "nullable": true },
          "email_safe": { "type": "boolean", "nullable": true },
          "utm_source": { "type": "string", "nullable": true },
          "utm_medium": { "type": "string", "nullable": true },
          "utm_campaign": { "type": "string", "nullable": true },
          "utm_content": { "type": "string", "nullable": true },
          "aspect_ratio": { "type": "string", "nullable": true },
          "is_public": { "type": "boolean", "nullable": true }
        },
        "additionalProperties": false
      },
      "GeneratePresentationRequest": {
        "type": "object",
        "required": ["content"],
        "properties": {
          "content": {
            "type": "string",
            "description": "The content/prompt for generating the presentation"
          },
          "n_slides": {
            "type": "integer",
            "description": "Number of slides. If omitted, auto-detected.",
            "default": 8
          },
          "language": {
            "type": "string",
            "description": "Presentation language. If omitted, auto-detected.",
            "default": "English"
          },
          "template": {
            "type": "string",
            "description": "Template group: general, travel, travel-itinerary, code, education, product-overview, report, etc.",
            "default": "general"
          },
          "tone": {
            "type": "string",
            "enum": ["default", "casual", "professional", "funny", "educational", "sales_pitch", "inspirational", "adventurous", "luxury"],
            "default": "default"
          },
          "verbosity": {
            "type": "string",
            "enum": ["concise", "standard", "text-heavy"],
            "default": "standard"
          },
          "web_search": {
            "type": "boolean",
            "default": false,
            "description": "Enable web search grounding"
          },
          "include_table_of_contents": {
            "type": "boolean",
            "default": false
          },
          "include_title_slide": {
            "type": "boolean",
            "default": true
          },
          "export_as": {
            "type": "string",
            "enum": ["pptx", "pdf", "html", "video"],
            "default": "pptx"
          },
          "origin": {
            "type": "string",
            "description": "Departure city for travel flight searches"
          },
          "currency": {
            "type": "string",
            "default": "USD",
            "description": "Currency for price formatting"
          },
          "slides_markdown": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Custom slide outlines"
          },
          "instructions": {
            "type": "string",
            "description": "Custom instructions for the AI"
          },
          "trigger_webhook": {
            "type": "boolean",
            "default": false
          },
          "slide_duration": {
            "type": "integer",
            "description": "Seconds per slide for video/HTML export"
          },
          "transition_style": {
            "type": "string",
            "enum": ["scale-zoom", "slide-right", "clip-reveal", "cycle", "random"],
            "default": "cycle",
            "description": "Video transition animation style"
          }
        }
      },
      "PresentationWithSlides": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "content": { "type": "string" },
          "n_slides": { "type": "integer" },
          "language": { "type": "string" },
          "title": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" },
          "tone": { "type": "string" },
          "verbosity": { "type": "string" },
          "theme": { "type": "object" },
          "slides": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/SlideModel" }
          }
        }
      },
      "SlideModel": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "layout_group": { "type": "string", "description": "Template group (e.g. 'travel', 'general')" },
          "layout": { "type": "string", "description": "Layout ID (e.g. 'travel:destination-hero')" },
          "index": { "type": "integer" },
          "content": { "type": "object", "description": "Structured slide data matching the layout's Zod schema" },
          "speaker_note": { "type": "string" },
          "html_content": { "type": "string" }
        }
      },
      "PresentationPathAndEditPath": {
        "type": "object",
        "required": ["presentation_id", "path", "edit_path"],
        "properties": {
          "presentation_id": { "type": "string" },
          "path": { "type": "string", "description": "File path to the exported file" },
          "edit_path": { "type": "string", "description": "URL path to edit the presentation in the UI" }
        }
      },
      "HTTPValidationError": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ValidationError" }
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "required": ["loc", "msg", "type"],
        "properties": {
          "loc": { "type": "array", "items": { "type": "string" } },
          "msg": { "type": "string" },
          "type": { "type": "string" }
        }
      },
      "GetPresentationSummaryResponse": {
        "type": "object",
        "required": ["success", "presentations", "total_presentations", "total_layouts"],
        "properties": {
          "success": { "type": "boolean" },
          "presentations": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PresentationSummary" }
          },
          "total_presentations": { "type": "integer" },
          "total_layouts": { "type": "integer" },
          "message": { "type": "string" }
        }
      },
      "PresentationSummary": {
        "type": "object",
        "required": ["presentation_id", "layout_count"],
        "properties": {
          "presentation_id": { "type": "string" },
          "layout_count": { "type": "integer" },
          "last_updated_at": { "type": "string", "format": "date-time" },
          "template": { "type": "object" }
        }
      },
      "NarrationGenerateRequest": {
        "type": "object",
        "properties": {
          "voice_id": { "type": "string" },
          "tone": { "type": "string" },
          "model_id": { "type": "string" },
          "force_regenerate": { "type": "boolean", "default": false }
        }
      },
      "NarrationSlideResponse": {
        "type": "object",
        "properties": {
          "slide_id": { "type": "string", "format": "uuid" },
          "audio_url": { "type": "string" },
          "text_hash": { "type": "string" },
          "generated_at": { "type": "string", "format": "date-time" },
          "voice_id": { "type": "string" },
          "tone": { "type": "string" },
          "model_id": { "type": "string" },
          "character_count": { "type": "integer" },
          "cached": { "type": "boolean" }
        }
      },
      "NarrationBulkResponse": {
        "type": "object",
        "properties": {
          "presentation_id": { "type": "string", "format": "uuid" },
          "total_slides": { "type": "integer" },
          "generated_slides": { "type": "integer" },
          "total_character_count": { "type": "integer" },
          "slides": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/NarrationSlideResponse" }
          }
        }
      },
      "NarrationEstimateSlide": {
        "type": "object",
        "properties": {
          "slide_id": { "type": "string", "format": "uuid" },
          "index": { "type": "integer" },
          "title": { "type": "string" },
          "has_speaker_note": { "type": "boolean" },
          "character_count": { "type": "integer" }
        }
      },
      "NarrationEstimateResponse": {
        "type": "object",
        "properties": {
          "presentation_id": { "type": "string", "format": "uuid" },
          "total_slides": { "type": "integer" },
          "synthesizeable_slides": { "type": "integer" },
          "total_character_count": { "type": "integer" },
          "max_character_limit": { "type": "integer" },
          "slides": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/NarrationEstimateSlide" }
          }
        }
      },
      "NarrationPresentationStatusResponse": {
        "type": "object",
        "properties": {
          "presentation_id": { "type": "string", "format": "uuid" },
          "slides": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/NarrationSlideResponse" }
          }
        }
      },
      "NarrationVoicesResponse": {
        "type": "object",
        "properties": {
          "voices": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "voice_id": { "type": "string" },
                "name": { "type": "string" },
                "category": { "type": "string" },
                "language": { "type": "string" },
                "description": { "type": "string" },
                "preview_url": { "type": "string" }
              }
            }
          },
          "cached": { "type": "boolean" },
          "source": { "type": "string" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["detail"],
        "properties": {
          "success": { "type": "boolean", "default": false },
          "detail": { "type": "string" },
          "error_code": { "type": "string" }
        }
      }
    }
  }
}
